{
  "id": "/",
  "name": "Patela Farm Management",
  "short_name": "Patela Farms",
  "description": "Offline-first farm management system",
  "categories": ["business", "productivity"],
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "lang": "en",
  "dir": "ltr",
  "background_color": "#ffffff",
  "theme_color": "#0871b3",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "/",
      "id": "patela-farms"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "shortcuts": [
    {
      "name": "Add Inventory",
      "short_name": "Inventory",
      "description": "Quickly add or update items",
      "url": "/inventory",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Record Sale",
      "short_name": "Sale",
      "description": "Record a new sale",
      "url": "/orders",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "note_taking": {
    "new_note_url": "/"
  },
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+patelafarm",
      "url": "/protocol?url=%s"
    }
  ],
  "scope_extensions": [
    { "origin": "https://localhost:3000" }
  ],
  "widgets": [
    {
      "name": "Patela Farm quick view",
      "short_name": "Patela Farm",
      "description": "Quick links into Patela Farm Management.",
      "tag": "patela-quick",
      "template": "patela-quick",
      "ms_ac_template": "/widgets/patela-quick-template.json",
      "data": "/widgets/patela-quick-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshots/narrow.png",
          "sizes": "540x720",
          "label": "Patela Farm widget",
          "platform": "Windows"
        }
      ],
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }],
      "auth": false,
      "update": 86400
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/narrow.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshots/wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    }
  ]
}

